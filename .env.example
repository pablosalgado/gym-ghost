RAILS_LOG_LEVEL=info
APP_HOSTS=gym.example.com
SECRET_KEY_BASE=replace-with-a-long-random-value
ATTR_ENCRYPTED_KEY=replace-with-a-32-byte-random-value

# Partner API configuration (downstream gym member authentication)
PARTNER_API_BASE_URL=http://localhost:9000

# Partner activities schedule API token (unauthenticated GET)
PARTNER_ACTIVITIES_TOKEN=

# Partner branches/facilities downstream (unauthenticated GET)
PARTNER_BRANCHES_API_BASE_URL=http://localhost:9000
PARTNER_BRANCHES_BRAND=TestBrand

# Request headers (Referer and Origin — set these to the partner website URL)
PARTNER_AUTH_REFERER=
PARTNER_AUTH_ORIGIN=
PARTNER_AUTH_TOKEN=

# Partner branch configuration (used in login payload partner_data)
TEST_PARTNER_AUTH_PARTNER_NAME=TestPartner
TEST_PARTNER_AUTH_BRANCH_ID=6
TEST_PARTNER_AUTH_BRANCH_NAME=Test Branch
TEST_PARTNER_AUTH_TOKEN_BRANCH=TOKEN001
TEST_PARTNER_AUTH_COUNTRY_CODE=CO

TEST_BRANCH_TOKEN=TOKEN001

# Smoke test credentials — set these in your local .env to run smoke tests
TEST_PARTNER_AUTH_EMAIL=your-test-member@partner.com
TEST_PARTNER_AUTH_PASSWORD=your-test-password

