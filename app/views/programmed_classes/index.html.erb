<% content_for :title, t(".page_title") %>

<div class="py-2">
  <h5 class="mb-3"><%= t(".heading") %></h5>

  <% if @programmed_classes.any? %>
    <div class="d-grid gap-2 pb-3">
      <% @programmed_classes.each do |pc| %>
        <% style = class_type_style(pc.class_type.name) %>
        <article class="card shadow-sm schedule-card" style="border-left-color: <%= style[:card] %>; background-color: <%= style[:card_bg] %>;">
          <div class="card-body p-3 d-flex justify-content-between align-items-center">
            <div>
              <div><strong><%= pc.class_type.name %></strong></div>
              <div><%= pc.facility.name %></div>
              <div class="small text-secondary"><%= l(pc.start_time, format: :long) %></div>
            </div>
            <div class="d-flex flex-column align-items-end gap-1">
              <span class="badge bg-<%= pc.programmed? ? 'primary' : pc.reserved? ? 'success' : pc.failed? ? 'danger' : 'secondary' %>">
                <%= pc.status %>
              </span>
              <% unless pc.reserved? %>
                <%= button_to pc, method: :delete, class: "btn btn-sm btn-outline-secondary", data: { turbo: false } do %>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                <% end %>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center text-secondary py-4">
        <%= t(".empty") %>
      </div>
    </div>
  <% end %>
</div>
