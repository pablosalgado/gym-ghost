<% content_for :title, "Schedule" %>

<div class="py-2 schedule-shell">
  <div class="schedule-sticky-controls">
    <%# Day navigation %>
    <div class="day-strip mb-3" role="navigation" aria-label="Choose day">
      <% (0..6).each do |offset| %>
        <% date = Date.today + offset %>
        <% is_active = offset == @selected_day %>
        <%= link_to schedules_path(day: offset, city: params[:city], facility: params[:facility], activity: params[:activity]),
              class: "btn #{is_active ? 'btn-primary' : 'btn-outline-secondary'} day-pill" do %>
          <span class="text-uppercase small fw-semibold"><%= date.strftime("%a") %></span>
          <span class="fw-bold"><%= date.day %></span>
        <% end %>
      <% end %>
    </div>

    <%# Filters %>
    <div class="card shadow-sm border-0 mb-3">
      <div class="card-body">
        <%= form_with url: schedules_path, method: :get, data: { turbo_action: "replace" } do |f| %>
          <%= hidden_field_tag :day, @selected_day %>

          <div class="row g-3">
            <div class="col-12 col-md-4">
              <%= f.select :city,
                    options_for_select([["All cities", ""]] + @cities.map { |city| [city.name, city.id] }, @selected_city.id),
                    {},
                    id: "city_filter",
                    class: "form-select",
                    onchange: "this.form.requestSubmit()" %>
            </div>

            <div class="col-12 col-md-4">
              <%= f.select :facility,
                    options_for_select([["All facilities", ""]] + @facilities.map { |facility| [facility.name, facility.id] }, @selected_facility.id),
                    {},
                    id: "facility_filter",
                    class: "form-select",
                    onchange: "this.form.requestSubmit()" %>
            </div>

            <div class="col-12 col-md-4">
              <%= f.select :activity,
                    options_for_select([["All activities", ""]] + @class_types.map { |activity| [activity.name, activity.id] }, @selected_class_type),
                    {},
                    id: "activity_filter",
                    class: "form-select",
                    onchange: "this.form.requestSubmit()" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Session list %>
  <div class="schedule-scroll-area">
    <% if @schedules.any? %>
      <div class="d-grid gap-2 pb-3">
        <% @schedules.each do |schedule| %>
          <% theme = activity_theme(schedule.class_type.name) %>
          <article class="card shadow-sm border-0 schedule-card activity-<%= theme %>">
            <div class="card-body p-3">
              <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                <span class="fs-5 fw-bold"><%= schedule.class_type.name %></span>
                <span class="badge rounded-pill activity-badge activity-badge-<%= theme %>"><%= schedule.start_time %></span>
              </div>

              <p class="mb-0 text-secondary">
                <strong class="text-dark"><%= schedule.facility.name %></strong>
                <span aria-hidden="true"> · </span>
                <span><%= schedule.facility.city.name %></span>
              </p>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-secondary py-4">
          No sessions available for the selected day and filters.
        </div>
      </div>
    <% end %>
  </div>
</div>
