<% content_for :title, "Schedule" %>

<div
  class="w-full"
  data-controller="schedule"
  data-schedule-sessions-value="<%= @sessions.to_json %>"
>
  <%# Week view header %>
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-4">Schedule</h1>

    <div class="flex gap-2 overflow-x-auto pb-2" data-schedule-target="weekStrip">
      <% (0..6).each do |offset| %>
        <button
          type="button"
          class="flex-1 min-w-[4rem] flex flex-col items-center py-3 px-2 rounded-xl border-2 transition-colors cursor-pointer
                 <%= offset == 0 ? 'border-indigo-600 bg-indigo-600 text-white' : 'border-gray-200 bg-white text-gray-700 hover:border-indigo-400' %>"
          data-schedule-target="dayButton"
          data-day="<%= offset %>"
          data-action="click->schedule#selectDay"
        >
          <span class="text-xs font-medium uppercase tracking-wide day-label"></span>
          <span class="text-lg font-bold day-number"></span>
        </button>
      <% end %>
    </div>
  </div>

  <%# Filters %>
  <div class="bg-gray-50 rounded-xl p-4 mb-6">
    <h2 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-3">Filters</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">City</label>
        <select
          class="w-full rounded-lg border-gray-300 border py-2 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400"
          data-schedule-target="cityFilter"
          data-action="change->schedule#filter"
        >
          <option value="">All cities</option>
          <% @cities.each do |city| %>
            <option value="<%= city %>"><%= city %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Facility</label>
        <select
          class="w-full rounded-lg border-gray-300 border py-2 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400"
          data-schedule-target="facilityFilter"
          data-action="change->schedule#filter"
        >
          <option value="">All facilities</option>
          <% @facilities.each do |facility| %>
            <option value="<%= facility %>"><%= facility %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-500 mb-1">Activity</label>
        <select
          class="w-full rounded-lg border-gray-300 border py-2 px-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400"
          data-schedule-target="activityFilter"
          data-action="change->schedule#filter"
        >
          <option value="">All activities</option>
          <% @activities.each do |activity| %>
            <option value="<%= activity %>"><%= activity %></option>
          <% end %>
        </select>
      </div>
    </div>
  </div>

  <%# Session list %>
  <div data-schedule-target="sessionList">
    <p class="text-gray-400 text-sm text-center py-8">Loading sessions…</p>
  </div>
</div>
