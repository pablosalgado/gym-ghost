<% content_for :title, "Schedule" %>

<div class="py-2 schedule-shell" data-controller="loading">
  <div class="schedule-loading-overlay d-none" data-loading-target="overlay">
    <div class="spinner-border text-primary" role="status">
      <span class="visually-hidden">Loading schedule...</span>
    </div>
  </div>
  <div class="schedule-sticky-controls">
    <%# Day navigation %>
    <div class="day-strip mb-3" role="navigation" aria-label="Choose day" data-controller="day-strip">
      <% (0..13).each do |offset| %>
        <% date = Date.today + offset %>
        <% is_active = offset == @selected_day %>
        <%= link_to schedules_path(day: offset, city: params[:city], facility: params[:facility], activity: params[:activity]),
              class: "btn #{is_active ? 'btn-primary' : 'btn-outline-secondary'} day-pill" do %>
          <span class="text-uppercase small fw-semibold"><%= date.strftime("%a") %></span>
          <span class="fw-bold"><%= date.day %></span>
        <% end %>
      <% end %>
    </div>

    <%# Filters %>
    <div class="card shadow-sm border-0 mb-3">
      <div class="card-body">
        <%= form_with url: schedules_path, method: :get, data: { turbo_action: "replace" } do |f| %>
          <%= hidden_field_tag :day, @selected_day %>

          <div class="row g-3">
            <div class="col-12 col-md-4">
              <%= f.select :city,
                    options_for_select([["All cities", ""]] + @cities.map { |city| [city.name, city.id] }, @selected_city.id),
                    {},
                    id: "city_filter",
                    class: "form-select",
                    onchange: "this.form.requestSubmit()" %>
            </div>

            <div class="col-12 col-md-4">
              <%= f.select :facility,
                    options_for_select(@facilities.map { |facility| [facility.name, facility.id] }, @selected_facility.id),
                    {},
                    id: "facility_filter",
                    class: "form-select",
                    onchange: "this.form.requestSubmit()" %>
            </div>

            <div class="col-12 col-md-4">
              <%= f.select :activity,
                    options_for_select([["All activities", ""]] + @class_types.map { |activity| [activity.name, activity.id] }, @selected_class_type&.id || ""),
                    {},
                    id: "activity_filter",
                    class: "form-select",
                    onchange: "this.form.requestSubmit()" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Session list %>
  <div class="schedule-scroll-area">
    <% if @schedules.any? %>
      <div class="d-grid gap-2 pb-3">
        <% @schedules.each do |schedule| %>
          <% style = class_type_style(schedule.class_type.name) %>
          <article class="card shadow-sm schedule-card" style="border-left-color: <%= style[:card] %>; background-color: <%= style[:card_bg] %>;">
            <div class="card-body p-3">
              <div><strong><%= schedule.class_type.name %></strong></div>
              <div><strong><%= schedule.facility.name %></strong></div>
              <div><strong><%= schedule.start_time.strftime("%H:%M") %></strong></div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-secondary py-4">
          No sessions available for the selected day and filters.
        </div>
      </div>
    <% end %>
  </div>
</div>
