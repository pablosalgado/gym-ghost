<% content_for :title, t(".page_title") %>

<div class="py-2 schedule-shell" data-controller="loading">
  <div class="schedule-loading-overlay d-none" data-loading-target="overlay">
    <div class="spinner-border text-primary" role="status">
      <span class="visually-hidden"><%= t(".loading") %></span>
    </div>
  </div>
  <div class="schedule-sticky-controls">
    <%# Day navigation %>
    <div class="day-strip mb-3" role="navigation" aria-label="<%= t(".choose_day") %>" data-controller="day-strip">
      <% (0..13).each do |offset| %>
        <% date = Date.today + offset %>
        <% is_active = offset == @selected_day %>
          <%= link_to schedules_path(day: offset, city: params[:city], facility: params[:facility], activity: params[:activity]),
                class: "btn #{is_active ? 'btn-primary' : 'btn-outline-secondary'} day-pill",
                data: { turbo_prefetch: false } do %>
          <span class="text-uppercase small fw-semibold"><%= I18n.l(date, format: "%a") %></span>
          <span class="fw-bold"><%= date.day %></span>
        <% end %>
      <% end %>
    </div>

    <%# Filters %>
    <div class="card shadow-sm border-0 mb-3">
      <div class="card-body">
        <%= form_with url: schedules_path, method: :get, data: { turbo_action: "replace" } do |f| %>
          <%= hidden_field_tag :day, @selected_day %>

          <div class="row g-3">
            <div class="col-12 col-md-4">
              <%= f.select :city,
                    options_for_select(@cities.map { |city| [city.name, city.id] }, @selected_city.id),
                    {},
                    id: "city_filter",
                    class: "form-select",
                    onchange: "this.form.requestSubmit()" %>
            </div>

            <div class="col-12 col-md-4">
              <%= f.select :facility,
                    options_for_select(@facilities.map { |facility| [facility.name, facility.id] }, @selected_facility.id),
                    {},
                    id: "facility_filter",
                    class: "form-select",
                    onchange: "this.form.requestSubmit()" %>
            </div>

            <div class="col-12 col-md-4">
              <%= f.select :activity,
                    options_for_select([[t(".all_activities"), ""]] + @class_types.map { |activity| [activity.name, activity.id] }, @selected_class_type&.id || ""),
                    {},
                    id: "activity_filter",
                    class: "form-select",
                    onchange: "this.form.requestSubmit()" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Session list %>
  <div class="schedule-scroll-area">
    <% if @schedules.any? %>
      <div class="d-grid gap-2 pb-3">
        <% @schedules.each do |schedule| %>
          <% style = class_type_style(schedule.class_type.name) %>
          <% programmed = @programmed_schedule_ids.include?(schedule.id) %>
          <%= button_to programmed_classes_path(schedule_id: schedule.id),
                class: "card shadow-sm schedule-card #{'programmed' if programmed}",
                style: "border-left-color: #{style[:card]}; background-color: #{style[:card_bg]};" do %>
            <div class="card-body p-3 d-flex justify-content-between align-items-center">
              <div>
                <div><strong><%= schedule.class_type.name %></strong></div>
                <div><strong><%= schedule.facility.name %></strong></div>
                <div><strong><%= schedule.start_time.strftime("%H:%M") %></strong></div>
              </div>
              <% if programmed %>
                <span class="badge bg-success rounded-pill"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-secondary py-4">
          <%= t(".no_sessions") %>
        </div>
      </div>
    <% end %>
  </div>
</div>
